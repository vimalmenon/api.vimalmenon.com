{
  "compilerOptions": {
    "preserveConstEnums": true,
    "strictNullChecks": true,
    "sourceMap": true,
    "allowJs": true,
    "target": "es5",
    "outDir": ".build",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "lib": ["es2015"],
    "rootDir": "./",
    "resolveJsonModule": true,
    "paths": {
      "@types": ["./src/types"],
      "@common": ["./src/common"]
    }
  }
}
